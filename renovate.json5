{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':semanticCommits',
    ':dependencyDashboard',
  ],
  timezone: 'America/Argentina/Buenos_Aires',
  schedule: ['before 6am on monday'],
  separateMinorPatch: true,
  prHourlyLimit: 4,
  prConcurrentLimit: 10,
  labels: ['dependencies', 'renovate'],

  // Manages Python dependencies (pyproject.toml / uv.lock) and the GitHub
  // Actions of the molecule workflow natively.

  customManagers: [
    // AuthKeySync binary version pinned in defaults/main.yml.
    {
      customType: 'regex',
      fileMatch: ['^defaults/main\\.yml$'],
      matchStrings: [
        '# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+authkeysync_version:\\s*["\']?(?<currentValue>[^"\'\\s]+)',
      ],
    },
  ],

  packageRules: [
    // Policy: NEVER automerge. Every PR goes through human review.
    // Majors are labeled as candidates for careful review.
    {
      matchUpdateTypes: ['major'],
      addLabels: ['major-update'],
    },
    {
      matchUpdateTypes: ['patch'],
      groupName: 'all patches',
      groupSlug: 'all-patches',
    },
  ],
}
