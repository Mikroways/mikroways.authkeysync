{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':semanticCommits',
    ':dependencyDashboard',
  ],
  timezone: 'America/Argentina/Buenos_Aires',
  schedule: [
    'before 6am on monday',
  ],
  separateMinorPatch: true,
  prHourlyLimit: 4,
  prConcurrentLimit: 10,
  labels: [
    'dependencies',
    'renovate',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^defaults/main\\.yml$/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+authkeysync_version:\\s*["\']?(?<currentValue>[^"\'\\s]+)',
      ],
    },
  ],
  packageRules: [
    {
      matchUpdateTypes: [
        'major',
      ],
      addLabels: [
        'major-update',
      ],
    },
    {
      matchUpdateTypes: [
        'patch',
      ],
      groupName: 'all patches',
      groupSlug: 'all-patches',
    },
  ],
}
