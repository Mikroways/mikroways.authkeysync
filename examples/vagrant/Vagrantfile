# -*- mode: ruby -*-
# vi: set ft=ruby :

# Por defecto el rol se resuelve desde el CÓDIGO LOCAL vía el symlink roles/
# (ver ansible.cfg). Alternativa: instalar el rol PUBLICADO desde el tag con
#   FROM_GALAXY=1 vagrant up
# Eso requiere que el tag exista en GitHub y acceso SSH al repo. La instalación
# de galaxy va a .galaxy-roles/ (gitignoreado) y ANSIBLE_ROLES_PATH apunta ahí,
# así no se usa el symlink local.
# Sin la variable (default) => "0" => false => symlink. Solo con FROM_GALAXY=1 => galaxy.
from_galaxy = ENV.fetch("FROM_GALAXY", "0") == "1"

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"

  config.vm.provider "virtualbox" do |vb|
    vb.memory = "1024"
  end

  config.vm.provision "ansible" do |ansible|
    ansible.playbook = "playbook.yml"
    if from_galaxy
      ansible.galaxy_role_file  = "../requirements.yml"
      ansible.galaxy_roles_path = ".galaxy-roles"
      ENV["ANSIBLE_ROLES_PATH"] = File.expand_path(".galaxy-roles", __dir__)
    end
  end
end
